generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ───────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String?   // "musician" | "venue"
  onboarded     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  musicianProfile MusicianProfile?
  venueProfile    VenueProfile?
}

model MusicianProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  bio         String  @default("")
  instruments String  @default("") // comma-separated
  genres      String  @default("") // comma-separated
  instagram   String  @default("")
  website     String  @default("")
  photoUrl    String  @default("")
  sampleTrackUrls String @default("") // comma-separated URLs
  yearsExperience Int  @default(0)
  available   Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gigInterests GigInterest[]
  invitations  Invitation[]
}

model VenueProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  name        String  @default("")
  description String  @default("")
  address     String  @default("")
  lat         Float?
  lng         Float?
  hoursJson   String  @default("") // JSON string of operating hours
  venueType   String  @default("") // restaurant, bar, lounge, club, etc.
  capacity    Int     @default(0)
  photoUrls   String  @default("") // comma-separated URLs
  website     String  @default("")
  phone       String  @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  gigs Gig[]
}

model Gig {
  id          String   @id @default(cuid())
  venueId     String
  title       String
  description String   @default("")
  date        DateTime
  startTime   String   // "19:00"
  endTime     String   // "22:00"
  genres      String   @default("") // comma-separated
  instruments String   @default("") // comma-separated desired instruments
  payMin      Int      @default(0)
  payMax      Int      @default(0)
  status      String   @default("open") // open, filled, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venue      VenueProfile @relation(fields: [venueId], references: [id], onDelete: Cascade)
  interests  GigInterest[]
  invitations Invitation[]
}

model GigInterest {
  id          String   @id @default(cuid())
  gigId       String
  musicianId  String
  message     String   @default("")
  status      String   @default("pending") // pending, accepted, declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gig      Gig              @relation(fields: [gigId], references: [id], onDelete: Cascade)
  musician MusicianProfile  @relation(fields: [musicianId], references: [id], onDelete: Cascade)

  @@unique([gigId, musicianId])
}

model Invitation {
  id          String   @id @default(cuid())
  gigId       String
  musicianId  String
  message     String   @default("")
  status      String   @default("pending") // pending, accepted, declined
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gig      Gig              @relation(fields: [gigId], references: [id], onDelete: Cascade)
  musician MusicianProfile  @relation(fields: [musicianId], references: [id], onDelete: Cascade)

  @@unique([gigId, musicianId])
}
